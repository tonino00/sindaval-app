{
  "rewrites": [
    {
      "source": "/api/v1/(.*)",
      "destination": "https://sindaval-api.onrender.com/api/v1/$1"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "https://sindaval-api.onrender.com/uploads/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
